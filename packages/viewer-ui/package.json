{
  "name": "@jagannathamv/viewer-ui",
  "version": "0.2.0",
  "description": "Astro-based session viewer UI for luma-browser",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/render.d.ts",
      "import": "./dist/render.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build --config vite.config.mjs && node scripts/copy-render-types.mjs"
  },
  "dependencies": {
    "astro": "^5.7.10"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "vite": "^6.3.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
